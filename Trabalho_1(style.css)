body {
  font-family: Arial, sans-serif;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: white;
  text-align: center;
  padding: 20px;
  margin: 0;
}

.quiz-box {
  background: rgba(255,255,255,0.1);
  padding: 25px;
  border-radius: 15px;
  max-width: 400px;
  margin: 50px auto;
  backdrop-filter: blur(10px);
  box-shadow: 0 10px 25px rgba(0,0,0,0.2);
}

#pergunta {
  margin-bottom: 20px;
}

button {
  display: block;
  margin: 10px auto;
  padding: 12px;
  width: 80%;
  border: none;
  border-radius: 8px;
  cursor: pointer;
  background: white;
  color: #333;
  font-size: 16px;
  transition: 0.3s;
}

button:hover {
  background: #ddd;
  transform: scale(1.05);
}

#resultado {
  margin-top: 20px;
  font-size: 18px;
  font-weight: bold;
}
